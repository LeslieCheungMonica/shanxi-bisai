{
    "$schema": "https://opencode.ai/config.json",
    "permission": "allow",
    "command": {
        "my-command": {
            "description": "My custom command",
            "template": "Do something with $1"
        }
    },
    "provider": {
        "local": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "local",
            "options": {
                "baseURL": "http://10.142.175.2:32028/v1",
                "apiKey": "407abc3a-7233-4908-a639-084342914674",
                "timeout": 3600000,
                "chunkTimeout": 120000
            },
            "models": {
                "Qwen3-Coder-30B": {
                    "name": "Qwen3-Coder-30B"
                }
            }
        },
    },
    "model": "local/",
    "small_model": "local/",
    "mcp": {
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        }
    }
}